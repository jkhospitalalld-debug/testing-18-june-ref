/* ---------------- JSON IMPORT ---------------- */
importJSONBtn.addEventListener('click', () => {
  jsonFileInput.click();
});

jsonFileInput.addEventListener('change', function () {

  const file = this.files[0];
  if (!file) return;
if(!confirm("Existing data merge hoga. Continue?")) {
  jsonFileInput.value = "";
  return;
}

  const reader = new FileReader();

  reader.onload = function (e) {
    try {
      const importedData = JSON.parse(e.target.result);

      if (!Array.isArray(importedData)) {
        alert("Invalid JSON format ❌");
        return;
      }

      let added = 0;
      let updated = 0;

      importedData.forEach(newPatient => {

        const index = registry.findIndex(p => p.id === newPatient.id);

        if (index >= 0) {
          registry[index] = newPatient;   // UPDATE
          updated++;
        } else {
          registry.push(newPatient);     // ADD NEW
          added++;
        }

      });

      localStorage.setItem(KEY_REGISTRY, JSON.stringify(registry));

      alert(`Backup Merge Done ✅\nNew: ${added}\nUpdated: ${updated}`);

    } catch (err) {
      alert("JSON file galat hai ❌");
    }
  };

  reader.readAsText(file);
  jsonFileInput.value = "";
});
