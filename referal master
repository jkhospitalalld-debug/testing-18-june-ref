function renderSavedList(search = "") {

  savedBody.innerHTML = '';
const filtered = registry.filter(p => {
  const q = search.toLowerCase();
  return (
    (p.form.name || "").toLowerCase().includes(q) ||
    (p.id || "").toLowerCase().includes(q)
  );
});
  if (filtered.length === 0) {
    savedBody.innerHTML = '<tr><td colspan="5" style="text-align:center">No saved patients</td></tr>';
    return;
  }

  filtered.forEach((p) => {

    const tr = document.createElement('tr');

    tr.innerHTML = `
      <td>${p.id}</td>
      <td>${p.form.name}</td>
      <td>${p.form.date}</td>
      <td><button data-id="${p.id}" class="btn addBtn">Load</button></td>
      <td><button data-del="${p.id}" class="danger-btn">Delete</button></td>
    `;

    savedBody.appendChild(tr);
  });

  // LOAD (SEARCH SAFE FIX)
savedBody.querySelectorAll('[data-id]').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    const id = btn.getAttribute('data-id');
    const patient = registry.find(p => p.id === id);
    loadPatient(patient);
    savedModal.style.display = 'none';
  });
});

  // DELETE
  savedBody.querySelectorAll('[data-del]').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    const id = btn.getAttribute('data-del');

    if(confirm("Delete this patient?")){
      const index = registry.findIndex(p => p.id === id);
      registry.splice(index,1);
      localStorage.setItem(KEY_REGISTRY, JSON.stringify(registry));
      renderSavedList(savedSearch.value);
    }
  });
});
    }  

function loadPatient(data){

  form = {...data.form};
  items = [...data.items];
  meds = [...data.meds];

  nameEl.value = form.name;
  ageEl.value = form.age;
  sexEl.value = form.sex;
  pmhEl.value = form.pmh;
  dateEl.value = form.date;
  billEl.value = form.billno || '';
  uhidEl.value = data.id;

  renderItems();
  renderMeds();
}
