    .row{display:flex;gap:12px;margin-top:14px;flex-wrap:wrap}
    .col{flex:1;min-width:160px}
    label{font-size:13px;color:var(--muted);margin-bottom:6px;display:block}
    input[type="text"],input[type="number"],select,textarea{width:100%;padding:10px;border-radius:10px;border:1px solid var(--border);background:#fff;font-size:15px}
