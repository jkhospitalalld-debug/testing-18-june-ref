/* render procedures */
function renderItems() {
  procBody.innerHTML = '';

  if (items.length === 0) {
    procBody.innerHTML =
      '<tr><td colspan="5" class="small" style="padding:12px;text-align:center;color:#6b7280">No procedures added yet.</td></tr>';
    return;
  }

  items.forEach((it, idx) => {

    if (!it.boxes) it.boxes = ["", "", "", ""];

    const tr = document.createElement('tr');

    tr.innerHTML = `
      <td style="vertical-align:middle">${esc(it.code)}</td>

      <td style="vertical-align:middle">${esc(it.procedure)}</td>

      <td style="vertical-align:middle">
        <table style="border-collapse:collapse;">
          <tr>
            <td><input class="tooth-box" type="text" data-box="0" data-idx="${idx}" value="${it.boxes[0]}"></td>
            <td><input class="tooth-box" type="text" data-box="1" data-idx="${idx}" value="${it.boxes[1]}"></td>
          </tr>
          <tr>
            <td><input class="tooth-box" type="text" data-box="2" data-idx="${idx}" value="${it.boxes[2]}"></td>
            <td><input class="tooth-box" type="text" data-box="3" data-idx="${idx}" value="${it.boxes[3]}"></td>
          </tr>
        </table>
      </td>

      <td style="vertical-align:middle">
        <input type="number" min="1" value="${it.no || 1}" data-idx="${idx}"
          style="width:96px;padding:8px;border-radius:8px;border:1px solid #eee"/>
      </td>

      <td style="text-align:center;vertical-align:middle" class="no-print">
        <button data-del="${idx}" class="danger-btn">Del</button>
      </td>
    `;

    procBody.appendChild(tr);
  });


  /* ⭐ SAVE TOOTH BOX VALUES */
  procBody.querySelectorAll('.tooth-box').forEach(box => {
    box.addEventListener('input', e => {
      const i = Number(e.target.dataset.idx);
      const b = Number(e.target.dataset.box);

      items[i].boxes[b] = e.target.value;
      saveItems();
    });
  });

  /* ⭐ QTY CHANGE */
  procBody.querySelectorAll('input[type="number"]').forEach(inp => {
    inp.addEventListener('change', e => {
      const i = Number(e.target.dataset.idx);
      items[i].no = Math.max(1, Number(e.target.value) || 1);
      saveItems();
    });
  });

  /* ⭐ DELETE ROW */
  procBody.querySelectorAll('button[data-del]').forEach(b => {
    b.addEventListener('click', () => {
      const i = Number(b.getAttribute('data-del'));
      items.splice(i, 1);
      saveItems();
      renderItems();
    });
  });

}



