    .controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .btn{padding:10px 14px;border-radius:10px;border:0;cursor:pointer;font-weight:700;font-size:14px}
    .btn-primary{background:var(--accent);color:#fff;box-shadow:0 6px 18px rgba(11,92,255,0.12)}
    .btn-muted{background:#fff;color:#111;border:1px solid var(--border)}
    .btn-ghost{background:transparent;border:1px dashed var(--border)}
    .addBtn{background:var(--primary);color:#fff}
    .danger-btn{background:var(--danger);color:#fff;padding:8px 10px;border-radius:8px;border:0;cursor:pointer}
    .small{font-size:13px;color:var(--muted)}
    .med-controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:8px}
    .proc-select{padding:12px;border-radius:10px;border:1px solid var(--border);background:#fff;font-size:15px;height:48px}
    select.proc-select{min-width:160px}
    .med-select,.med-dose,.med-duration{padding:10px;border-radius:10px;border:1px solid var(--border);background:#fff;height:44px;font-size:15px}
    .footer{font-size:13px;color:var(--muted);margin-top:10px;text-align:center}
    @media (max-width:900px){
      .meta{width:100%;justify-content:space-between}
