/* ------------- init ------------- */
function init(){ const today=new Date(); dateEl.value=form.date||today.toISOString().slice(0,10); nameEl.value=form.name||''; ageEl.value=form.age||''; sexEl.value=form.sex||'M'; pmhEl.value=form.pmh||''; billEl.value=form.billno||''; populateProcedureSelects(); populateMedDropdown(); renderMeds(); renderItems(); updateUHID(); }
