/* ------------- UHID ------------- */
function genUHID(){ const dateVal=dateEl.value||new Date().toISOString().slice(0,10); const d=new Date(dateVal); const yyyy=d.getFullYear(); const mm=String(d.getMonth()+1).padStart(2,'0'); const bill=(billEl.value||'').toString().trim(); if(bill){ const numeric=/^\d+$/.test(bill); const last=numeric?String(bill).padStart(4,'0'):bill.replace(/\s+/g,'-'); return `${yyyy}/${mm}/${SYSTEM_ID}${last}`; } else { const monthKey=`${yyyy}${mm}`; const counterKey=`uhid_counter_v9_${monthKey}`; let cnt=Number(localStorage.getItem(counterKey)||0); if(form.uhid && form.date && form.date.slice(0,7)===`${yyyy}-${mm}` 
   && form.uhid.startsWith(`${yyyy}/${mm}/${SYSTEM_ID}`)) 
   return form.uhid; cnt=cnt+1; localStorage.setItem(counterKey,String(cnt)); return `${yyyy}/${mm}/${SYSTEM_ID}${String(cnt).padStart(4,'0')}`; } }
function updateUHID(){ uhidEl.value=genUHID(); form.uhid=uhidEl.value; saveForm(); }

